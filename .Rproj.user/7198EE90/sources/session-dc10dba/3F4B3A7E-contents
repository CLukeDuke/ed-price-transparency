# -----------------------------------------------------------------------------
# heat_color()
# Interpolate between green (low cost) and orange (high cost) based on where
# a value falls within its row's [min, max] range.
# Returns an RGB string like "rgb(225, 245, 238)"
#
# Used by the heatmap table in the All Conditions tab.
# The reactable JS version in app.R does the same math client-side for
# performance — this R version is available for server-side use or testing.
# -----------------------------------------------------------------------------
heat_color <- function(value, row_min, row_max) {
  if (row_max == row_min) return("rgb(225, 245, 238)")  # all same → green

  t <- (value - row_min) / (row_max - row_min)  # t in [0, 1]

  if (t < 0.5) {
    # Interpolate: teal-50 (#E1F5EE) → teal-100 (#9FE1CB)
    r <- round(225 + (185 - 225) * t * 2)
    g <- round(245 + (218 - 245) * t * 2)
    b <- round(238 + (201 - 238) * t * 2)
  } else {
    # Interpolate: coral-50 (#FAECE7) → coral-100 (#F5C4B3)
    tt <- (t - 0.5) * 2
    r  <- round(250 + (245 - 250) * tt)
    g  <- round(236 + (196 - 236) * tt)
    b  <- round(231 + (179 - 231) * tt)
  }

  sprintf("rgb(%d, %d, %d)", r, g, b)
}
