# -----------------------------------------------------------------------------
# find_match()
# Fuzzy keyword matching: maps a user's free-text symptom to one of our known
# PRICE_DATA keys. Returns NULL if no match found.
#
# Strategy:
#   1. Exact match first (fastest, most reliable)
#   2. Any keyword in the query longer than 3 chars matches a key word
#   3. NULL → caller will try the Claude API instead
#
# We deliberately keep this simple. A production version might use:
#   - stringdist::stringsim() for edit distance
#   - text embeddings for semantic matching
#   - The Claude API itself for classification
# -----------------------------------------------------------------------------
find_match <- function(query) {
  query <- stringr::str_to_lower(stringr::str_trim(query))
  keys  <- names(PRICE_DATA)

  # Pass 1: exact match
  if (query %in% keys) return(query)

  # Pass 2: any content word in query appears in a key
  query_words <- stringr::str_split(query, "\\s+")[[1]]
  query_words <- query_words[nchar(query_words) > 3]  # skip short words

  for (key in keys) {
    key_words <- stringr::str_split(key, "\\s+")[[1]]
    if (any(query_words %in% key_words)) return(key)
  }

  # Pass 3: any key word appears in the query
  for (key in keys) {
    key_words <- stringr::str_split(key, "\\s+")[[1]]
    key_words <- key_words[nchar(key_words) > 3]
    if (any(sapply(key_words, function(w) stringr::str_detect(query, w)))) return(key)
  }

  NULL  # No match — caller will escalate to Claude API
}

# -----------------------------------------------------------------------------
# fmt_dollar()
# Format a numeric value as a dollar string.
# scales::dollar() does this, but we wrap it so we can change the format once.
# Example: fmt_dollar(3640) → "$3,640"
# -----------------------------------------------------------------------------
fmt_dollar <- function(x) {
  scales::dollar(round(x), prefix = "$", big.mark = ",")
}

# -----------------------------------------------------------------------------
# get_hospital_name()
# Given a condition's data list, find which hospital has the min or max of a
# specific price field. Used to populate the "lowest cash price at X" value box.
#
# d       — a single PRICE_DATA entry (list with $prices sub-list)
# field   — the price field: "cash", "gross", "min_neg", or "max_neg"
# which   — "min" or "max"
# -----------------------------------------------------------------------------
get_hospital_name <- function(d, field, which_fn = "min") {
  vals <- sapply(names(d$prices), function(hid) d$prices[[hid]][[field]])

  target_id <- if (which_fn == "min") {
    names(which.min(vals))
  } else {
    names(which.max(vals))
  }

  # Look up the full name from the HOSPITALS data frame
  hosp_row <- HOSPITALS[HOSPITALS$id == target_id, ]
  if (nrow(hosp_row) == 0) return(target_id)
  hosp_row$name[1]
}

