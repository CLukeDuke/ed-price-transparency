# -----------------------------------------------------------------------------
# 1. LOAD LIBRARIES
# Every package must be installed before running. If you get "there is no
# package called X", run: install.packages("X") in the console first.
# -----------------------------------------------------------------------------
library(shiny)          # Core Shiny framework — UI + server reactivity
library(bslib)          # Bootstrap 5 themes for modern-looking UI
library(dplyr)          # Data manipulation: filter, arrange, mutate, etc.
library(ggplot2)        # Grammar of graphics — all our charts
library(plotly)         # Converts ggplot2 charts to interactive HTML widgets
library(httr2)          # Modern HTTP client — used to call the Anthropic API
library(jsonlite)       # Parse JSON responses from the API
library(scales)         # Formatting helpers: dollar(), comma(), etc.
library(stringr)        # String manipulation: str_detect, str_to_lower, etc.
library(glue)           # String interpolation: glue("Hello {name}")
library(reactable)      # Interactive sortable/filterable data tables

