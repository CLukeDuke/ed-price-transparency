# -----------------------------------------------------------------------------
# Helper: build a standard prices list for one hospital
# Used repeatedly below to avoid copy-pasting the same structure 7 times.
# -----------------------------------------------------------------------------
price_entry <- function(gross, cash, min_neg, max_neg) {
  list(gross = gross, cash = cash, min_neg = min_neg, max_neg = max_neg)
}

